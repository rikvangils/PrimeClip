# PeanutClip AutoFlow — environment variables
# Copy to .env and fill in each value. NEVER commit the real .env to source control.

# ── App ──────────────────────────────────────────────────────────────────────
PEANUTCLIP_APP_NAME=PeanutClip AutoFlow

# ── Database ─────────────────────────────────────────────────────────────────
# Full SQLAlchemy connection string for the PostgreSQL database.
PEANUTCLIP_DATABASE_URL=postgresql+psycopg://postgres:changeme@localhost:5432/peanutclip

# ── YouTube / source monitor ─────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → API key
# API must have YouTube Data API v3 enabled.
PEANUTCLIP_YOUTUBE_API_KEY=replace_me

# JSON list of whitelisted YouTube channel IDs or handles.
PEANUTCLIP_SOURCE_CHANNEL_WHITELIST=["theburntpeanut"]

# ── Publishing provider ───────────────────────────────────────────────────────
# "buffer"  → schedule via Buffer API (requires BUFFER_ACCESS_TOKEN + profile IDs)
# "tiktok" → schedule directly via TikTok Content Posting API (requires TIKTOK_ACCESS_TOKEN)
# "manual"  → export JSON bundles to MANUAL_PUBLISH_EXPORT_DIR
PEANUTCLIP_PUBLISH_PROVIDER=manual

# ── Buffer (required when PEANUTCLIP_PUBLISH_PROVIDER=buffer) ────────────────
# 1. Use an existing Buffer legacy developer token.
# 2. Call GET https://api.bufferapp.com/1/profiles.json?access_token=<token>
#    to retrieve the profile IDs for each social account.
PEANUTCLIP_BUFFER_ACCESS_TOKEN=awxr89gwkeyjpldn
PEANUTCLIP_BUFFER_API_BASE_URL=https://api.bufferapp.com/1
PEANUTCLIP_BUFFER_PROFILE_ID_INSTAGRAM=replace_me
PEANUTCLIP_BUFFER_PROFILE_ID_TIKTOK=replace_me

# ── TikTok (required when PEANUTCLIP_PUBLISH_PROVIDER=tiktok) ─────────────────
# Access token from your TikTok app OAuth flow with video.upload scope.
PEANUTCLIP_TIKTOK_ACCESS_TOKEN=eyJ...  ← kort geldig (~24u)
PEANUTCLIP_TIKTOK_REFRESH_TOKEN=rft... ← lang geldig (~30 dagen), voor automatische vernieuwing
PEANUTCLIP_TIKTOK_API_BASE_URL=https://open.tiktokapis.com
PEANUTCLIP_TIKTOK_CLIENT_KEY=awxr89gwkeyjpldn
PEANUTCLIP_TIKTOK_CLIENT_SECRET=jtPNf0X6MRaMod3jUyq7s3v5oxAex3b8
PEANUTCLIP_TIKTOK_REDIRECT_URI=http://localhost:8000/review/integrations/tiktok/oauth/callback

# ── Instagram (optional direct analytics) ────────────────────────────────────
PEANUTCLIP_INSTAGRAM_ACCESS_TOKEN=

# ── Render output ─────────────────────────────────────────────────────────────
PEANUTCLIP_RENDER_OUTPUT_DIR=generated/renders
PEANUTCLIP_MANUAL_PUBLISH_EXPORT_DIR=generated/publish_queue

# Path to the ffmpeg binary (must be on PATH, or use absolute path).
PEANUTCLIP_FFMPEG_BINARY=ffmpeg